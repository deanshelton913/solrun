# Redis (optional). Use when your Redis server requires auth or a custom host/port.
# Examples: redis://localhost:6379  or  redis://:password@localhost:6379
# REDIS_URL=

# Google Maps: used for destination detail maps and POIs (Static Maps + Places APIs).
# Enable Maps Static API and Places API (Text Search) in Google Cloud Console.
# GOOGLE_MAPS_API_KEY=

# Optional: base URL for "Compare flights" partner links (earn via affiliate).
# Defaults to Skyscanner. Use your Skyscanner/Kayak partner URL to earn commission.
# Leave unset to use default. Set to empty to hide the links.
# NEXT_PUBLIC_FLIGHT_SEARCH_BASE_URL=https://www.skyscanner.com/transport/flights

# Google AdSense (optional). Set to show inline ads. Use the client= value from your
# AdSense script snippet (e.g. script src="...?client=ca-pub-XXXXXXXX").
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx
# Slot for the horizontal ad in weather results (data-ad-slot from your unit).
# Default in code: 8123844359. Override here if you use a different slot.
# NEXT_PUBLIC_ADSENSE_SLOT_INLINE=8123844359

# DEVELOPMENT TOOLS
# Ideally, don't add them to production deployment envs
NEXT_PUBLIC_SHOW_LOGGER="false"